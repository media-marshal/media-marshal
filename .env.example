# Media Marshal 环境变量配置模板

# ── 调试 ─────────────────────────────────────────────────────
# 开启后打印详细中间过程日志，生产环境保持 false
MEDIA_MARSHAL_DEBUG=false

# ── 必填 ─────────────────────────────────────────────────────
# TMDB API Key（从 https://www.themoviedb.org/settings/api 申请）
MEDIA_MARSHAL_TMDB_API_KEY=your_tmdb_api_key_here

# ── 文件监控 ─────────────────────────────────────────────────
# 宿主机媒体目录（挂载到容器 /media）
MEDIA_DIRS=/your/media/path

# 匹配置信度阈值（0.0-1.0），低于此值进入待确认队列
MEDIA_MARSHAL_CONFIDENCE_THRESHOLD=0.8

# ── 邮件通知（可选）────────────────────────────────────────
MEDIA_MARSHAL_EMAIL_ENABLED=false
MEDIA_MARSHAL_EMAIL_RECIPIENT=you@example.com
MEDIA_MARSHAL_MAIL_HOST=smtp.gmail.com
MEDIA_MARSHAL_MAIL_PORT=587
MEDIA_MARSHAL_MAIL_USERNAME=your@gmail.com
MEDIA_MARSHAL_MAIL_PASSWORD=your_app_password
